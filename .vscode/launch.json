{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Backend",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/deal-tracker/backend/server.js",
            "cwd": "${workspaceFolder}/deal-tracker/backend"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Frontend (Chrome)",
            "url": "http://localhost:5000",
            "webRoot": "${workspaceFolder}/deal-tracker/frontend"
        }
    ],
    "compounds": [
        {
            "name": "Launch Full-Stack (DealTrack Pro)",
            "configurations": [
                "Launch Backend",
                "Launch Frontend (Chrome)"
            ]
        }
    ]
}